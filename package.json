{
  "name": "nextum-lms",
  "version": "1.0.0",
  "description": "강의실 도면과 요일별 타임테이블을 만드는 Electron 앱",
  "main": "dist/main.js",
  "scripts": {
    "copy:fonts": "node scripts/copy-fonts.js",
    "build:css": "npx tailwindcss -i renderer/styles/tailwind.css -o renderer/styles/tailwind.out.css --minify",
    "build:renderer": "npm run build:css && node esbuild.config.js",
    "build:main": "npx tsc",
    "build": "npm run build:main && npm run build:renderer",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "start": "npm run build && electron .",
    "start:js": "electron .",
    "dev:css": "npx tailwindcss -i renderer/styles/tailwind.css -o renderer/styles/tailwind.out.css --watch",
    "dev:renderer": "cross-env NODE_ENV=development node esbuild.config.js --watch",
    "dev:main": "npx tsc --watch",
    "dev:electron": "nodemon",
    "dev": "npm run build:main && cross-env NODE_ENV=development node esbuild.config.js && concurrently \"npm run dev:main\" \"npm run dev:css\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "clean": "rimraf dist renderer/bundle.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "electron-builder install-app-deps && npm run copy:fonts"
  },
  "dependencies": {
    "@fontsource/noto-sans-kr": "^5.2.9",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/supabase-js": "^2.93.3",
    "@tanstack/react-virtual": "^3.13.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.29.2",
    "lucide-react": "^0.563.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^30.0.0",
    "electron-builder": "^26.4.0",
    "electron-rebuild": "^3.2.9",
    "electron-reloader": "^1.2.3",
    "esbuild": "^0.27.2",
    "jsdom": "^27.4.0",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.6",
    "rimraf": "^5.0.7",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.nextum.lms",
    "productName": "NEXTUM LMS",
    "asar": true,
    "icon": "build/icon.png",
    "asarUnpack": [
      "**/*.node"
    ],
    "compression": "store",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "build/icons/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icons/icon.icns",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    }
  }
}

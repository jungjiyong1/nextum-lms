{
  "name": "nextum-lms",
  "version": "1.0.0",
  "description": "NEXTUM LMS web application",
  "scripts": {
    "postinstall": "node scripts/copy-pdfjs-assets.mjs",
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint . && npm run ui:check",
    "ui:check": "node scripts/check-ui-system.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf .next out dist",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "bundle:check": "node scripts/check-client-bundle-budgets.mjs",
    "deadcode": "knip --include files,dependencies,unlisted,unresolved",
    "verify": "npm run lint && npm run typecheck && npm run test:coverage && npm run deadcode && npm run build && npm run bundle:check",
    "db:check": "node scripts/check-lms-db-health.mjs",
    "db:import-grade-fixtures": "node scripts/import-grade-app-fixtures.mjs",
    "db:verify-gaeppul-light": "node scripts/verify-gaeppul-middle-light.mjs",
    "db:import-studyq-bank": "node scripts/import-studyq-bank.mjs",
    "db:backup-content": "node scripts/backup-grade-content.mjs",
    "db:backup-preservation": "node scripts/backup-nextum-data-preservation.mjs",
    "db:bootstrap-learning-analysis": "node scripts/bootstrap-learning-analysis.mjs",
    "seed:dev-admin": "node scripts/seed-lms-dev-admin.mjs",
    "smoke:lms": "node scripts/smoke-lms-runtime.mjs"
  },
  "dependencies": {
    "@fontsource/noto-sans-kr": "^5.2.9",
    "@napi-rs/canvas": "1.0.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.93.3",
    "@tesseract.js-data/eng": "1.0.0",
    "@tesseract.js-data/kor": "1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "next": "^16.2.10",
    "pdfjs-dist": "6.1.200",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tesseract.js": "7.0.0",
    "tus-js-client": "4.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^27.4.0",
    "knip": "5.71.0",
    "postcss": "^8.5.16",
    "rimraf": "^5.0.7",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.62.1",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
